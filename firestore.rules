rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /players/{id} {
      allow read: if resource.data.published == true || request.auth != null;
      allow write: if request.auth != null;
    }
    match /articles/{id} {
      allow read: if resource.data.published == true || request.auth != null;
      allow write: if request.auth != null;
    }
    match /rankings/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /consensus/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /siteContent/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /eoiSubmissions/{id} {
      allow read, write: if request.auth != null;
    }
    match /roles/{id} {
      allow read, write: if request.auth != null;
    }
    match /communityReports/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
